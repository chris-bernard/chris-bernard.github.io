---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  class="bg-lightModeIconLinkBackground dark:bg-darkModeIconLinkBackground border-lightModeIconLinkOutline dark:border-darkModeIconLinkOutline text-lightModeIconLinkText dark:text-darkModeIconLinkText hover:bg-lightModeIconLinkBackgroundHover dark:hover:bg-darkModeIconLinkBackgroundHover cursor-pointer rounded-full border p-2 transition-colors"
  aria-label="Toggle theme"
>
  <Icon name="sun" class="size-5 dark:hidden" />
  <Icon name="moon" class="hidden size-5 dark:block" />
</button>

<script is:inline>
  function initTheme() {
    const theme = (() => {
      if (
        typeof localStorage !== "undefined" &&
        localStorage.getItem("theme")
      ) {
        return localStorage.getItem("theme");
      }
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
      }
      return "light";
    })();

    if (theme === "light") {
      document.documentElement.classList.remove("dark");
    } else {
      document.documentElement.classList.add("dark");
    }

    localStorage.setItem("theme", theme);

    const handleToggleClick = (event) => {

      const x = event.clientX;
      const y = event.clientY;
      const endRadius = Math.hypot(
        Math.max(x, innerWidth - x),
        Math.max(y, innerHeight - y),
      );

      const transition = document.startViewTransition(() => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });

      transition.ready.then(() => {
        const clipPath = [
          `circle(0px at ${x}px ${y}px)`,
          `circle(${endRadius}px at ${x}px ${y}px)`,
        ];
        console.log("clipPath: " + document.documentElement.classList.contains("dark"));
        document.documentElement.animate(
          {
            clipPath: clipPath,
          },
          {
            duration: 400,
            easing: "ease-in",
            pseudoElement: "::view-transition-new(root)",
          },
        );
      });
    };

    document
      .getElementById("theme-toggle")
      ?.addEventListener("click", handleToggleClick);
  }

  document.addEventListener("astro:page-load", initTheme);
</script>
