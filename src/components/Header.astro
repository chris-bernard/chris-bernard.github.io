---
import { SITE } from "@/siteConfig";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="bg-lightModeIconLinkBackground dark:bg-darkModeIconLinkBackground border-b border-lightModeIconLinkOutline dark:border-darkModeIconLinkOutline mb-8">
  <div class="px-3 sm:px-6 flex items-center justify-between py-4">
    <div class="hidden sm:flex flex-1 items-center">
      <a href="/" class="inline-flex items-center hover:opacity-80 transition-opacity">
        <img src="/favicon-32x32-cb.png" alt="Logo" class="w-8 h-8 shrink-0 border-lightModeIconLinkOutline dark:border-darkModeIconLinkOutline" />
      </a>
    </div>
    <div class="flex items-center text-center text-sm font-semibold tracking-normal sm:tracking-widest text-lightModeForegroundMuted dark:text-darkModeForegroundMuted mx-2 sm:mx-4">
      {SITE.role}
    </div>
    <div class="flex-1 flex justify-end">
      <ThemeToggle />
    </div>
  </div>
</header>
