---
import "@/styles/global.css";

import BaseHead from "@/components/BaseHead.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<html lang="en">
  <BaseHead>
    <slot name="head" />
  </BaseHead>
  <body class="mx-auto min-h-screen max-w-screen-sm p-3 font-sans sm:p-6 bg-lightModeBackground dark:bg-darkModeBackground">
    <ThemeToggle />
    <slot />

    <!-- Preventing "Flash of Unstyled Content" (FOUC) -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          console.log('Theme preference found in localStorage: ' + localStorage.getItem('theme'));
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          console.log('Dark mode preferred by user: dark');
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }

      window.localStorage.setItem('theme', theme);
    </script>

  </body>
</html>
